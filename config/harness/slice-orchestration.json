{
  "$schema": "./slice-orchestration.schema.json",
  "version": "1.0.0",
  "project": "lienliberator",
  "phase": 1,
  "description": "Multi-agent harness orchestration for BUILD_SPEC Phase 1 slices 1-11. Each slice runs the same agent pipeline in order; agents may be skipped only when MANIFEST.harness_state resumes mid-loop.",
  "global_agent_pipeline": [
    {
      "order": 1,
      "role": "ROUTER",
      "prompt": "prompts/agents/ROUTER.md",
      "may_edit_code": false,
      "outputs": [".claude/session/{slice_id}/route.json"],
      "exit_when": "route.json written with next_agent and slice_id"
    },
    {
      "order": 2,
      "role": "PLANNER",
      "prompt": "prompts/agents/PLANNER.md",
      "may_edit_code": false,
      "outputs": [".claude/session/{slice_id}/plan.md"],
      "exit_when": "plan.md has Scope, Files, Tests, Risks sections"
    },
    {
      "order": 3,
      "role": "IMPLEMENTER",
      "prompt": "prompts/agents/IMPLEMENTER.md",
      "may_edit_code": true,
      "outputs": ["git diff vs base branch"],
      "exit_when": "all plan.md tasks checked; no out-of-scope files"
    },
    {
      "order": 4,
      "role": "REVIEWER",
      "prompt": "prompts/agents/REVIEWER.md",
      "may_edit_code": false,
      "outputs": [".claude/session/{slice_id}/review-round-{n}.json"],
      "exit_when": "review JSON emitted",
      "loop": {
        "condition": "issues.length > 0",
        "next_agent": "IMPLEMENTER",
        "max_rounds": 5,
        "then": "VERIFIER"
      }
    },
    {
      "order": 5,
      "role": "VERIFIER",
      "prompt": "prompts/agents/VERIFIER.md",
      "may_edit_code": false,
      "outputs": [".claude/session/{slice_id}/verification.json"],
      "exit_when": "all gates pass OR blocked status set",
      "loop": {
        "condition": "verification.failed_gates.length > 0",
        "next_agent": "IMPLEMENTER",
        "max_rounds": 3,
        "abbreviated_reviewer": true,
        "then": "slice_complete"
      }
    }
  ],
  "slices": [
    {
      "id": "slice-01",
      "number": 1,
      "title": "Migrations + RLS + SBI seed",
      "week": 1,
      "depends_on": [],
      "spec_refs": ["BUILD_SPEC.md §5", "BUILD_SPEC.md §4.1", "BUILD_SPEC.md §16"],
      "scope_files": [
        "supabase/migrations/001_extensions_enums.sql",
        "supabase/migrations/002_reference_tables.sql",
        "supabase/migrations/003_identity_tables.sql",
        "supabase/migrations/004_cases.sql",
        "supabase/migrations/005_evidence_action_logs.sql",
        "supabase/migrations/006_escalations_swarm.sql",
        "supabase/migrations/007_jobs_consent_fees.sql",
        "supabase/migrations/008_rankings_audit.sql",
        "supabase/migrations/009_functions_triggers.sql",
        "supabase/migrations/010_rls_views_seed.sql",
        "supabase/database.types.ts"
      ],
      "forbidden_in_slice": ["app/**", "components/**", "lib/agents/**"],
      "acceptance_criteria": [
        "All 10 migrations apply cleanly on fresh Supabase local",
        "case_status enum matches BUILD_SPEC §4.1 exactly (13 values)",
        "18 tables exist per BUILD_SPEC §5.1",
        "SBI seed: bank slug state-bank-of-india, nodal customer.care@sbi.co.in",
        "Playbooks seeded: innocent_receiver_upi_chain_sbi, victim_upi_chain_sbi, innocent_receiver_upi_chain_generic",
        "RLS enabled on all user-owned tables; service role bypass documented",
        "action_logs, consent_records, swarm_events have append-only triggers",
        "Money columns are BIGINT *_paise only"
      ],
      "verification": {
        "commands": [
          "pnpm typecheck",
          "pnpm verify:no-auto-send"
        ],
        "optional": [
          "supabase db reset && supabase migration list"
        ],
        "grep_gates": [
          "case_status enum includes human_escalation",
          "no FLOAT amount columns in migrations"
        ]
      },
      "agent_notes": {
        "PLANNER": "Map each migration file to tables; do not create API routes.",
        "IMPLEMENTER": "Copy from workspace supabase/ if present; normalize to lienliberator/supabase/.",
        "REVIEWER": "Cross-check enum values against §16 trap list."
      }

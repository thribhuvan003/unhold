{
  "name": "unhold",
  "version": "0.1.0",
  "private": true,
  "description": "A guided case workspace for bank-account and UPI restrictions in India.",
  "license": "MIT",
  "homepage": "https://www.unhold.live",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thribhuvan003/unhold.git"
  },
  "bugs": {
    "url": "https://github.com/thribhuvan003/unhold/issues"
  },
  "author": "thribhuvan003 <thribhuvan003@gmail.com>",
  "packageManager": "pnpm@10.12.1",
  "engines": {
    "node": ">=22.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "@tailwindcss/oxide",
      "esbuild",
      "sharp",
      "supabase",
      "unrs-resolver"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit && pnpm test:contract && pnpm verify:no-auto-send && pnpm build",
    "test:unit": "vitest run tests/unit",
    "test:contract": "vitest run tests/contract",
    "test:e2e:smoke": "playwright test tests/e2e --grep @smoke",
    "test:e2e": "playwright test tests/e2e",
    "test:agents:golden": "vitest run tests/unit/agents/golden",
    "eval:notice": "node --env-file=.env.local scripts/eval/run.mjs",
    "eval:consistency": "node --env-file=.env.local scripts/eval/consistency.mjs",
    "verify:no-auto-send": "bash scripts/verify-no-auto-send.sh"
  },
  "dependencies": {
    "@supabase/ssr": "0.6.1",
    "@supabase/supabase-js": "2.49.8",
    "@upstash/ratelimit": "2.0.5",
    "@upstash/redis": "1.34.9",
    "@vercel/analytics": "^1.5.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "jszip": "3.10.1",
    "lucide-react": "0.511.0",
    "next": "16.2.9",
    "next-intl": "4.13.2",
    "pdf-lib": "1.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "sharp": "0.34.2",
    "supermemory": "4.24.12",
    "tailwind-merge": "3.3.0",
    "unpdf": "^1.6.2",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.10.1",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.1.8",
    "@types/jsdom": "^28.0.3",
    "@types/node": "22.15.29",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "eslint": "9.28.0",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "prettier": "3.5.3",
    "supabase": "2.24.3",
    "tailwindcss": "4.1.8",
    "typescript": "5.8.3",
    "vitest": "3.2.1"
  }
}
